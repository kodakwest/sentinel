{
  "name": "sentinel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "deploy": "npm run build && npm run db:migrate && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply sentinel-db --local",
    "db:migrate": "wrangler d1 migrations apply sentinel-db --remote"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.475.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "typescript": "^5.9.0",
    "vite": "^7.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260508.0",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "wrangler": "^4.14.0"
  }
}
