# Sentinel Architecture

External Sources -> Staging: "FDA/DailyMed/RxNorm"
Staging -> AI Pipeline: "raw text"
AI Pipeline -> Workers AI: "remap request"
Workers AI -> AI Pipeline: "summaries"
AI Pipeline -> D1 Database: "enriched drugs"
AI Pipeline -> Graph: "entities+edges"
Ontologies -> Condition Pipeline: "OBO files"
Condition Pipeline -> D1 Database: "conditions"
Condition Pipeline -> Graph: "hierarchy"
D1 Database -> Drug API: "query drugs"
D1 Database -> Condition API: "query conditions"
D1 Database -> Explain API: "drug context"
Drug API -> Frontend: "drug dossier"
Condition API -> Frontend: "condition view"
Explain API -> Frontend: "AI explanation"
Frontend -> Nurse: "UI"
Drug API -> AI Pipeline: "async enrichment"
Admin API -> D1 Database: "refresh/update"
D1 Database -> Admin API: "results"
Admin API -> Drug API: "mark stale"
Nurse -> Frontend: "search/browse"
Nurse -> Frontend: "ask question"
